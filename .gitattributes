#global default
* text=auto eol=lf

#source code
*.py     text eol=lf
*.rs     text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf

#Windows Specifics: Force CRLF (Batch files MUST have CRLF to run)
*.bat    text eol=crlf
*.cmd    text eol=crlf

#binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.mov    binary
*.mp3    binary
*.wav    binary
*.flac   binary
*.exe    binary

#configs
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
